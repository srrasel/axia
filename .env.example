# Twelve Data (market quotes)
TWELVE_DATA_API_KEY=your_api_key_here
JWT_SECRET=change-me-to-a-long-random-string

# Domains + SSL (after: bash deploy/ssl-init.sh)
SSL_EMAIL=admin@nitajfx.online
WEB_ORIGIN=https://my.nitajfx.online
API_PUBLIC_URL=https://api.nitajfx.online
# Leave empty so SPA uses same-origin /api via nginx (recommended).
# Set to https://api.nitajfx.online only if the SPA must call the API host directly.
VITE_API_URL=
CORS_ORIGIN=https://my.nitajfx.online,https://account.nitajfx.online,http://localhost:3000,http://localhost:3001

# Payment gateways (optional)
STRIPE_SECRET_KEY=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
