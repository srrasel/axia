# Twelve Data (market quotes)
TWELVE_DATA_API_KEY=your_api_key_here
JWT_SECRET=change-me-to-a-long-random-string

# Domains — DNS A records → your server IP
#   my.nitajfx.online | account.nitajfx.online | api.nitajfx.online
WEB_ORIGIN=http://my.nitajfx.online
API_PUBLIC_URL=http://api.nitajfx.online
VITE_API_URL=http://api.nitajfx.online
CORS_ORIGIN=http://my.nitajfx.online,http://account.nitajfx.online,https://my.nitajfx.online,https://account.nitajfx.online

# After SSL is enabled, switch the three URLs above to https://

# Payment gateways (optional — also Admin → Settings → Payments)
STRIPE_SECRET_KEY=
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
